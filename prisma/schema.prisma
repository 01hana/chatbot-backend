generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// System-wide configuration key-value store.
/// All runtime-tunable thresholds and text are stored here.
model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}

// ─── Phase 1: Safety ─────────────────────────────────────────────────────────

/// Prompt-injection and jailbreak detection patterns.
model SafetyRule {
  id        Int      @id @default(autoincrement())
  type      String   /// e.g. "prompt_injection" | "jailbreak" | "confidential"
  pattern   String   /// regex string or plain keyword
  isRegex   Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("safety_rules")
}

/// Confidential / sensitive keyword blacklist.
model BlacklistEntry {
  id        Int      @id @default(autoincrement())
  keyword   String   @unique
  type      String   /// confidential | internal | pricing_sensitive
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("blacklist_entries")
}

// ─── Phase 1: Intent ─────────────────────────────────────────────────────────

/// Intent classification templates including follow-up question templates.
model IntentTemplate {
  id          Int      @id @default(autoincrement())
  intent      String   @unique /// e.g. "product-inquiry"
  label       String   /// human-readable label
  keywords    String[] /// keyword hints used for detection
  templateZh  String   /// follow-up question template (zh-TW)
  templateEn  String   /// follow-up question template (en)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("intent_templates")
}

/// Product glossary — term aliases and synonym mapping.
model GlossaryTerm {
  id          Int      @id @default(autoincrement())
  term        String   @unique
  synonyms    String[] /// alternate forms / abbreviations
  intentLabel String?  /// associated intent (optional)
  createdAt   DateTime @default(now())

  @@map("glossary_terms")
}

// ─── Phase 1: Knowledge ──────────────────────────────────────────────────────

/// Knowledge base entries used for RAG retrieval.
model KnowledgeEntry {
  id          Int               @id @default(autoincrement())
  title       String
  content     String
  intentLabel String?
  tags        String[]
  status      String            @default("draft") /// draft | approved | archived
  visibility  String            @default("private") /// public | private
  version     Int               @default(1)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  versions    KnowledgeVersion[]

  @@map("knowledge_entries")
}

/// Immutable version snapshots of KnowledgeEntry content.
model KnowledgeVersion {
  id             Int            @id @default(autoincrement())
  knowledgeEntry KnowledgeEntry @relation(fields: [knowledgeEntryId], references: [id])
  knowledgeEntryId Int
  versionNumber  Int
  contentSnapshot String
  createdAt      DateTime       @default(now())

  @@map("knowledge_versions")
}

// ─── Phase 2: Conversation ────────────────────────────────────────────────────

/// A chat session, identified externally by `session_token` (UUID).
/// The `sessionId` field is the internal unique string key; `session_token` is
/// what the frontend stores and sends to all Chat API endpoints.
model Conversation {
  id                   Int                   @id @default(autoincrement())
  /// Internal UUID used inside the backend (not exposed to frontend)
  sessionId            String                @unique @default(uuid())
  /// External UUID returned to the frontend on session creation
  session_token        String                @unique @default(uuid())
  /// Session lifecycle status: active | closed
  status               String                @default("active")
  /// Conversation classification: normal | confidential
  type                 String                @default("normal")
  /// Aggregated risk level: low | medium | high | null
  riskLevel            String?
  /// Accumulated count of blocked/sensitive turns in this session
  sensitiveIntentCount Int                   @default(0)
  /// Running high-intent score for lead-capture triggering
  highIntentScore      Int                   @default(0)
  /// JSONB blob for product-diagnosis state machine context (Phase 4)
  diagnosisContext     Json?
  /// Detected language of the conversation: zh-TW | en
  language             String                @default("zh-TW")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?

  messages ConversationMessage[]

  @@map("conversations")
}

/// Individual messages within a Conversation.
model ConversationMessage {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  /// Message author: user | assistant | system
  role           String
  content        String
  /// Message classification: normal | confidential | blocked
  type           String       @default("normal")
  /// Risk level of this specific message: low | medium | high | null
  riskLevel      String?
  /// Reason the message was blocked, if applicable
  blockedReason  String?
  createdAt      DateTime     @default(now())

  @@map("conversation_messages")
}

// ─── Phase 2: Audit ───────────────────────────────────────────────────────────

/// Append-only audit trail of all pipeline events.
/// IMPORTANT: Rows must NEVER be updated or deleted.
/// `sessionId` is a plain String reference (no FK constraint) to avoid
/// cascade-delete risks on an immutable audit table.
model AuditLog {
  id               Int      @id @default(autoincrement())
  /// X-Request-ID header value (traceability)
  requestId        String?
  /// References Conversation.sessionId (no FK — intentional)
  sessionId        String?
  /// Event type: chat_response | prompt_guard_blocked | confidential_refused |
  ///   sensitive_intent_alert | llm_fallback | lead_created | ticket_created …
  eventType        String
  /// Arbitrary JSON payload for the event
  eventData        Json?
  /// Array of KnowledgeEntry IDs used in the RAG step
  knowledgeRefs    String[] @default([])
  /// Top RAG similarity score for this turn (null when RAG was skipped)
  ragConfidence    Float?
  /// Human-readable block reason (PromptGuard / confidentiality)
  blockedReason    String?
  /// SHA-256 hex digest of the raw user input (for prompt-injection audit)
  promptHash       String?
  /// LLM token usage — 0 when LLM was not called
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  /// Actual wall-clock time for this pipeline turn in milliseconds
  durationMs       Int      @default(0)
  /// LLM model identifier (e.g. "gpt-5.4-mini") — null when LLM not called
  aiModel          String?
  /// LLM provider identifier (e.g. "openai") — null when LLM not called
  aiProvider       String?
  /// Snapshot of relevant SystemConfig values at the time of the event
  configSnapshot   Json?
  createdAt        DateTime @default(now())

  @@map("audit_logs")
}
